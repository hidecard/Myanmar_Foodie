{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  },
  "env": {
    "BOT_TOKEN": "@bot_token",
    "TURSO_DATABASE_URL": "@turso_database_url",
    "TURSO_AUTH_TOKEN": "@turso_auth_token",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index.js"
    }
  ]
}
